                <div class="card-thumb"><img src="https://img.gamedistribution.com/540d36010bb94e288a660456efaebff9-512x512.jpeg" alt="Football 3D" loading="lazy" onerror="this.src='https://picsum.photos/seed/football15/400/225'"><div class="card-badge badge-top">⭐ Top</div><div class="card-overlay"><div class="play-btn-overlay"><i class="fas fa-play"></i> Play Now</div></div></div>
                <div class="card-body"><div class="card-meta"><span class="card-genre">Action</span><span class="card-rating"><i class="fas fa-star"></i> 4.8</span></div><h3 class="card-title">Football 3D</h3><p class="card-desc">Take to the pitch in this slick 3D football game. Score, tackle, win!</p><div class="card-footer"><span class="card-players"><i class="fas fa-circle"></i> 5.8k playing</span><button class="btn-play"><i class="fas fa-play"></i> Play</button></div></div>
            </div>
