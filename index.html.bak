    <!-- ════ JAVASCRIPT ════ -->
    <script>
     
        const GAMES = [
			{ id:13, title:"Fruit Match",  embedUrl:"https://html5.gamedistribution.com/4254dba037de4b798541d2c97eae5016/?gd_sdk_referrer_url=https://www.vortexly.com/games/fruit-match" },
            { id:14, title:"Fruit Swipe",  embedUrl:"https://html5.gamedistribution.com/644044c3831d4d77a6cee53e6b9d01c9/?gd_sdk_referrer_url=https://www.vortexly.com/games/fruit-swipe" },
            { id:15, title:"Football 3D",  embedUrl:"https://html5.gamedistribution.com/540d36010bb94e288a660456efaebff9/?gd_sdk_referrer_url=https://www.vortexly.com/games/football-3d" },
            { id:16, title:"Action Blitz", embedUrl:"https://html5.gamedistribution.com/a2b83c1a317c4eb0bffcc4ffcece5ef9/?gd_sdk_referrer_url=https://www.vortexly.com/games/action-blitz" },
          
            
        ];

        /* ── Viewer ── */
        const viewer    = document.getElementById('gameViewer');
        const vTitle    = document.getElementById('viewerTitle');
        const vGame     = document.getElementById('viewerGame');
        const vClose    = document.getElementById('viewerClose');
        const vFull     = document.getElementById('viewerFullscreen');

        function openGame(id) {
            const g = GAMES.find(x => x.id === id);
            if (!g) return;
            vTitle.textContent = g.title;
            if (g.embedUrl) {
                vGame.innerHTML = `<iframe src="${g.embedUrl}" allowfullscreen scrolling="no" frameborder="0" title="${g.title}"></iframe>`;
            } else {
                vGame.innerHTML = `
                    <div class="placeholder-msg">
                        <i class="fas fa-gamepad big-icon"></i>
                        <p style="font-size:1rem;color:var(--text);margin-bottom:8px">${g.title}</p>
                        <p>Embed URL coming soon — check back later!</p>
                    </div>`;
            }
            viewer.classList.add('open');
            document.body.style.overflow = 'hidden';
            // Update URL (good for SEO / sharing)
            history.pushState({gameId:id}, '', `?game=${id}`);
        }

        function closeGame() {
            viewer.classList.remove('open');
            document.body.style.overflow = '';
            setTimeout(() => { vGame.innerHTML = ''; }, 350);
            history.pushState({}, '', location.pathname);
        }

        vClose.addEventListener('click', closeGame);
        viewer.addEventListener('click', e => { if (e.target === viewer) closeGame(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeGame(); });

        // Fullscreen button
        vFull.addEventListener('click', () => {
            const iframe = vGame.querySelector('iframe');
            if (iframe) {
                (iframe.requestFullscreen || iframe.webkitRequestFullscreen || function(){}).call(iframe);
            }
        });

        // Auto-open game from URL on page load
        window.addEventListener('load', () => {
            const params = new URLSearchParams(location.search);
            const gid = parseInt(params.get('game'));
            if (gid) openGame(gid);
        });

        /* ── Card click ── */
        document.querySelectorAll('.game-card').forEach(card => {
            card.addEventListener('click', () => openGame(parseInt(card.dataset.gameId)));
        });

        /* ── Search ── */
        const notice   = document.getElementById('searchNotice');
        const noResult = document.getElementById('noResults');

        function handleSearch(q) {
            const term = q.trim().toLowerCase();
            const cards = document.querySelectorAll('.game-card');
            // Reset category pills
            document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active'));
            document.querySelector('.cat-pill[data-filter="all"]').classList.add('active');

            let visible = 0;
            cards.forEach(card => {
                const title = card.querySelector('.card-title').textContent.toLowerCase();
                const desc  = card.querySelector('.card-desc').textContent.toLowerCase();
                const match = !term || title.includes(term) || desc.includes(term);
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            });

            noResult.style.display = visible === 0 ? 'block' : 'none';
            if (term) {
                notice.style.display = 'block';
                notice.innerHTML = `Showing results for <span>"${q}"</span> — ${visible} game${visible !== 1 ? 's' : ''} found. <a href="#" onclick="clearSearch();return false" style="color:var(--hot)">Clear</a>`;
            } else {
                notice.style.display = 'none';
            }
            document.getElementById('gameCount').textContent = `// ${visible} title${visible !== 1 ? 's' : ''}`;
        }

        function clearSearch() {
            document.querySelectorAll('#searchInput, .mobile-search input').forEach(el => el.value = '');
            handleSearch('');
        }

        /* ── Category filter ── */
        function filterByCategory(cat) {
            clearSearch();
            const pills = document.querySelectorAll('.cat-pill');
            pills.forEach(p => p.classList.remove('active'));
            document.querySelector(`.cat-pill[data-filter="${cat}"]`)?.classList.add('active');

            const cards = document.querySelectorAll('.game-card');
            let visible = 0;
            cards.forEach(card => {
                const match = cat === 'all' || card.dataset.cat === cat;
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            noResult.style.display = visible === 0 ? 'block' : 'none';
            document.getElementById('gameCount').textContent = `// ${visible} title${visible !== 1 ? 's' : ''}`;
            // Smooth scroll to games section
            document.getElementById('gamesSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        document.querySelectorAll('.cat-pill').forEach(pill => {
            pill.addEventListener('click', () => filterByCategory(pill.dataset.filter));
        });

        /* ── Mobile nav ── */
        function toggleMobileNav() {
            document.getElementById('mobileNav').classList.toggle('open');
        }

        /* ── Cookie banner ── */
        function acceptCookie() {
            localStorage.setItem('cookieConsent', 'accepted');
            document.getElementById('cookieBanner').classList.add('hidden');
        }
        function dismissCookie() {
            localStorage.setItem('cookieConsent', 'declined');
            document.getElementById('cookieBanner').classList.add('hidden');
        }
        // Hide if already answered
        if (localStorage.getItem('cookieConsent')) {
            document.getElementById('cookieBanner').classList.add('hidden');
        }
    </script>
</body>
</html>
