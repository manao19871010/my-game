<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- ── SEO Meta  ── -->
    <title>Vortexly — Free Online Games, No Download Required</title>
    <meta name="description" content="Play 100% free browser games instantly — no download, no sign-up. Action, puzzle, casual & strategy games updated weekly. Play on desktop or mobile.">
    <meta name="keywords" content="free online games, browser games, no download games, play free games, html5 games, casual games, puzzle games">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://www.vortexly.com/">

    <!-- ── Open Graph  ── -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="Vortexly — Free Online Games">
    <meta property="og:description" content="Play free browser games instantly. No download, no sign-up.">
    <meta property="og:url" content="https://www.vortexly.com/">
    <meta property="og:image" content="https://www.vortexly.com/og-image.jpg">

    <!-- ── Fonts ── -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* ════════════════════════════════════════
           DESIGN TOKENS
        ════════════════════════════════════════ */
        :root {
            --bg:        #0a0a0f;
            --surface:   #12121a;
            --card:      #1a1a26;
            --border:    #2a2a3e;
            --neon:      #00f5a0;
            --neon2:     #00d9f5;
            --hot:       #ff3d71;
            --gold:      #ffd166;
            --text:      #e8e8f0;
            --muted:     #7070a0;
            --font-head: 'Bebas Neue', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-body);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Grid background */
        body::before {
            content: '';
            position: fixed; inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 40px 40px;
            opacity: 0.2;
            pointer-events: none;
            z-index: 0;
        }

        /* Glow blobs */
        .blob { position: fixed; border-radius: 50%; filter: blur(120px); opacity: 0.1; pointer-events: none; z-index: 0; }
        .blob-1 { width: 600px; height: 600px; background: var(--neon);  top: -200px; left: -200px; }
        .blob-2 { width: 500px; height: 500px; background: var(--neon2); bottom: -150px; right: -100px; }
        .blob-3 { width: 300px; height: 300px; background: var(--hot);   top: 40%; left: 50%; }

        /* ════════════════════════════════════════
           COOKIE BANNER 
        ════════════════════════════════════════ */
        #cookieBanner {
            position: fixed;
            bottom: 24px; left: 50%; transform: translateX(-50%);
            z-index: 999;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px;
            max-width: 640px; width: calc(100% - 40px);
            display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
            box-shadow: 0 20px 60px rgba(0,0,0,0.6);
            transition: opacity 0.4s, transform 0.4s;
        }
        #cookieBanner.hidden { opacity: 0; transform: translateX(-50%) translateY(20px); pointer-events: none; }
        #cookieBanner p { font-size: 0.83rem; color: var(--muted); line-height: 1.6; flex: 1; min-width: 200px; }
        #cookieBanner p a { color: var(--neon); }
        .cookie-btns { display: flex; gap: 10px; flex-shrink: 0; }
        .btn-cookie-accept {
            background: var(--neon); color: #0a0a0f;
            border: none; padding: 9px 20px; border-radius: 8px;
            font-weight: 700; font-size: 0.82rem; cursor: pointer; letter-spacing: 0.04em;
            transition: opacity 0.2s;
        }
        .btn-cookie-accept:hover { opacity: 0.85; }
        .btn-cookie-decline {
            background: transparent; color: var(--muted);
            border: 1px solid var(--border); padding: 9px 20px; border-radius: 8px;
            font-size: 0.82rem; cursor: pointer;
            transition: color 0.2s, border-color 0.2s;
        }
        .btn-cookie-decline:hover { color: var(--text); border-color: var(--muted); }

        /* ════════════════════════════════════════
           HEADER / NAV
        ════════════════════════════════════════ */
        header {
            position: sticky; top: 0; z-index: 100;
            background: rgba(10,10,15,0.88);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--border);
        }
        .nav-inner {
            max-width: 1400px; margin: 0 auto; padding: 0 2rem;
            height: 64px; display: flex; align-items: center; justify-content: space-between; gap: 16px;
        }
        .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .logo-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--neon), var(--neon2));
            border-radius: 8px; display: flex; align-items: center; justify-content: center;
            color: #0a0a0f; font-size: 18px;
        }
        .logo-text { font-family: var(--font-head); font-size: 1.8rem; letter-spacing: 2px; color: var(--text); }
        .logo-text span { color: var(--neon); }

        nav { display: flex; gap: 4px; }
        nav a {
            color: var(--muted); text-decoration: none;
            font-size: 0.82rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase;
            padding: 6px 14px; border-radius: 6px; transition: color 0.2s, background 0.2s;
        }
        nav a:hover { color: var(--neon); background: rgba(0,245,160,0.08); }
        nav a.active { color: var(--neon); }

        /* Search bar */
        .nav-search {
            display: flex; align-items: center;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 8px; overflow: hidden;
            transition: border-color 0.2s;
        }
        .nav-search:focus-within { border-color: rgba(0,245,160,0.5); }
        .nav-search input {
            background: transparent; border: none; outline: none;
            color: var(--text); font-family: var(--font-body); font-size: 0.82rem;
            padding: 7px 12px; width: 180px;
        }
        .nav-search input::placeholder { color: var(--muted); }
        .nav-search button {
            background: transparent; border: none; cursor: pointer;
            color: var(--muted); padding: 7px 12px;
            transition: color 0.2s;
        }
        .nav-search button:hover { color: var(--neon); }

        .nav-badge {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(0,245,160,0.12); border: 1px solid rgba(0,245,160,0.3);
            color: var(--neon); font-family: var(--font-mono); font-size: 0.7rem;
            padding: 4px 12px; border-radius: 20px; white-space: nowrap;
        }
        .nav-badge::before {
            content: ''; width: 6px; height: 6px;
            background: var(--neon); border-radius: 50%;
            animation: pulse 2s infinite;
        }

        /* Mobile menu toggle */
        .nav-menu-btn {
            display: none; background: transparent; border: none;
            color: var(--text); font-size: 1.2rem; cursor: pointer;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(0.8); }
        }

        /* ════════════════════════════════════════
           HERO
        ════════════════════════════════════════ */
        .hero {
            position: relative; z-index: 1;
            text-align: center; padding: 80px 2rem 60px;
            max-width: 1400px; margin: 0 auto;
        }
        .hero-tag {
            display: inline-block; font-family: var(--font-mono); font-size: 0.75rem;
            color: var(--neon); letter-spacing: 0.15em; text-transform: uppercase;
            border: 1px solid rgba(0,245,160,0.35); padding: 5px 14px; border-radius: 20px;
            margin-bottom: 24px; background: rgba(0,245,160,0.05);
        }
        .hero h1 {
            font-family: var(--font-head); font-size: clamp(3.5rem, 8vw, 7rem);
            line-height: 0.95; letter-spacing: 3px; margin-bottom: 20px;
        }
        .hero h1 em {
            font-style: normal;
            background: linear-gradient(90deg, var(--neon), var(--neon2));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .hero p { color: var(--muted); font-size: 1.05rem; max-width: 520px; margin: 0 auto 40px; line-height: 1.7; }
        .hero-stats { display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; }
        .stat { text-align: center; }
        .stat-num { font-family: var(--font-head); font-size: 2rem; letter-spacing: 1px; color: var(--neon); }
        .stat-label { font-size: 0.75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; }

        /* ════════════════════════════════════════
           FEATURE BANNER
        ════════════════════════════════════════ */
        .feature-banner { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 0 2rem 60px; }
        .banner-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
        .banner-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 12px; padding: 24px 20px;
            display: flex; align-items: flex-start; gap: 16px; transition: border-color 0.2s;
        }
        .banner-card:hover { border-color: rgba(0,245,160,0.3); }
        .banner-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
        .icon-green { background: rgba(0,245,160,0.12); color: var(--neon); }
        .icon-blue  { background: rgba(0,217,245,0.12); color: var(--neon2); }
        .icon-red   { background: rgba(255,61,113,0.12); color: var(--hot); }
        .icon-gold  { background: rgba(255,209,102,0.12); color: var(--gold); }
        .banner-text h4 { font-weight: 600; font-size: 0.95rem; margin-bottom: 4px; }
        .banner-text p { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }

        /* ════════════════════════════════════════
           GAMES SECTION
        ════════════════════════════════════════ */
        .section { max-width: 1400px; margin: 0 auto; padding: 0 2rem 80px; position: relative; z-index: 1; }
        .section-header { display: flex; align-items: baseline; gap: 16px; margin-bottom: 32px; }
        .section-header h2 { font-family: var(--font-head); font-size: 2.2rem; letter-spacing: 2px; }
        .section-header .count { font-family: var(--font-mono); font-size: 0.8rem; color: var(--muted); }

        /* Search results notice */
        #searchNotice {
            display: none; font-size: 0.85rem; color: var(--muted);
            margin-bottom: 20px; padding: 10px 16px;
            background: var(--surface); border-radius: 8px; border: 1px solid var(--border);
        }
        #searchNotice span { color: var(--neon); }

        /* Category pills */
        .categories { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 36px; }
        .cat-pill {
            display: flex; align-items: center; gap: 6px;
            padding: 7px 16px; border-radius: 20px;
            border: 1px solid var(--border); background: var(--surface);
            color: var(--muted); font-size: 0.82rem; font-weight: 500;
            cursor: pointer; transition: all 0.2s; user-select: none;
        }
        .cat-pill:hover { border-color: var(--neon); color: var(--neon); }
        .cat-pill.active { border-color: var(--neon); background: rgba(0,245,160,0.1); color: var(--neon); }

        /* Game grid */
        .game-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
        #noResults { display: none; grid-column: 1/-1; text-align: center; padding: 60px 0; color: var(--muted); }
        #noResults i { font-size: 2.5rem; margin-bottom: 12px; color: var(--border); }

        /* Game card */
        .game-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 14px; overflow: hidden; cursor: pointer;
            transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
            position: relative;
            animation: fadeUp 0.45s ease both;
        }
        .game-card:hover {
            transform: translateY(-6px);
            border-color: rgba(0,245,160,0.4);
            box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 30px rgba(0,245,160,0.08);
        }
        .card-thumb { position: relative; overflow: hidden; }
        .card-thumb img { width: 100%; height: 180px; object-fit: cover; display: block; transition: transform 0.4s; }
        .game-card:hover .card-thumb img { transform: scale(1.05); }
        .card-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(10,10,15,0.9) 0%, transparent 50%);
            display: flex; align-items: flex-end; padding: 12px;
            opacity: 0; transition: opacity 0.25s;
        }
        .game-card:hover .card-overlay { opacity: 1; }
        .play-btn-overlay {
            width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px;
            padding: 10px; background: var(--neon); color: #0a0a0f;
            font-weight: 700; font-size: 0.9rem; letter-spacing: 0.05em; border-radius: 8px;
        }
        .card-badge {
            position: absolute; top: 12px; left: 12px;
            font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600;
            text-transform: uppercase; padding: 3px 8px; border-radius: 4px; letter-spacing: 0.08em;
        }
        .badge-hot  { background: var(--hot);  color: #fff; }
        .badge-new  { background: var(--neon); color: #0a0a0f; }
        .badge-top  { background: var(--gold); color: #0a0a0f; }
        .badge-free { background: var(--neon2); color: #0a0a0f; }
        .card-body { padding: 16px; }
        .card-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
        .card-genre { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); }
        .card-rating { display: flex; align-items: center; gap: 4px; font-family: var(--font-mono); font-size: 0.72rem; color: var(--gold); }
        .card-title { font-family: var(--font-head); font-size: 1.35rem; letter-spacing: 1px; margin-bottom: 6px; }
        .card-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.6; margin-bottom: 16px; }
        .card-footer { display: flex; align-items: center; justify-content: space-between; }
        .card-players { font-size: 0.75rem; color: var(--muted); display: flex; align-items: center; gap: 5px; }
        .card-players i { color: var(--neon); font-size: 0.65rem; }
        .btn-play {
            display: flex; align-items: center; gap: 6px;
            background: transparent; border: 1px solid var(--neon); color: var(--neon);
            padding: 7px 16px; border-radius: 7px; font-weight: 600; font-size: 0.82rem;
            cursor: pointer; transition: all 0.2s; letter-spacing: 0.03em;
        }
        .btn-play:hover { background: var(--neon); color: #0a0a0f; }

        /* ════════════════════════════════════════
           GAME VIEWER MODAL
        ════════════════════════════════════════ */
        .game-viewer {
            position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,0.92); backdrop-filter: blur(8px);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            padding: 20px; opacity: 0; pointer-events: none; transition: opacity 0.3s;
        }
        .game-viewer.open { opacity: 1; pointer-events: all; }
        .viewer-inner {
            width: 100%; max-width: 1100px;
            background: var(--card); border: 1px solid var(--border); border-radius: 16px;
            overflow: hidden;
            transform: translateY(30px);
            transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .game-viewer.open .viewer-inner { transform: translateY(0); }
        .viewer-bar {
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 20px; border-bottom: 1px solid var(--border); background: var(--surface);
        }
        .viewer-title { font-family: var(--font-head); font-size: 1.3rem; letter-spacing: 1px; display: flex; align-items: center; gap: 10px; }
        .viewer-dot { width: 8px; height: 8px; background: var(--neon); border-radius: 50%; animation: pulse 1.5s infinite; }
        .viewer-actions { display: flex; align-items: center; gap: 8px; }
        .viewer-fullscreen {
            background: rgba(0,245,160,0.1); border: 1px solid rgba(0,245,160,0.3); color: var(--neon);
            width: 36px; height: 36px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.2s; font-size: 0.9rem;
        }
        .viewer-fullscreen:hover { background: rgba(0,245,160,0.25); }
        .viewer-close {
            background: rgba(255,61,113,0.12); border: 1px solid rgba(255,61,113,0.3); color: var(--hot);
            width: 36px; height: 36px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.2s; font-size: 1rem;
        }
        .viewer-close:hover { background: var(--hot); color: #fff; }
        .viewer-game {
            aspect-ratio: 16/9; width: 100%;
            background: var(--bg); display: flex; align-items: center; justify-content: center;
            color: var(--muted); font-family: var(--font-mono); font-size: 0.85rem;
        }
        .viewer-game iframe { width: 100%; height: 100%; border: none; display: block; }
        .placeholder-msg { text-align: center; }
        .placeholder-msg .big-icon { font-size: 3rem; margin-bottom: 12px; color: var(--border); display: block; }
        .placeholder-msg p { color: var(--muted); font-size: 0.85rem; }

        /* ════════════════════════════════════════
           FOOTER
        ════════════════════════════════════════ */
        footer {
            position: relative; z-index: 1;
            background: var(--surface); border-top: 1px solid var(--border);
            padding: 56px 2rem 32px;
        }
        .footer-inner {
            max-width: 1400px; margin: 0 auto;
            display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px;
        }
        .footer-logo-text { font-family: var(--font-head); font-size: 1.6rem; letter-spacing: 2px; margin-bottom: 10px; }
        .footer-logo-text span { color: var(--neon); }
        .footer-desc { color: var(--muted); font-size: 0.85rem; line-height: 1.7; margin-bottom: 20px; }
        .social-links { display: flex; gap: 10px; }
        .social-link {
            width: 36px; height: 36px; border-radius: 8px; border: 1px solid var(--border);
            display: flex; align-items: center; justify-content: center;
            color: var(--muted); text-decoration: none; transition: all 0.2s; font-size: 0.9rem;
        }
        .social-link:hover { border-color: var(--neon); color: var(--neon); }
        .footer-col h5 { font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; }
        .footer-col ul { list-style: none; }
        .footer-col ul li { margin-bottom: 10px; }
        .footer-col ul li a { color: var(--muted); text-decoration: none; font-size: 0.85rem; transition: color 0.2s; }
        .footer-col ul li a:hover { color: var(--neon); }
        .footer-bottom {
            max-width: 1400px; margin: 40px auto 0; padding-top: 24px;
            border-top: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
        }
        .footer-bottom p { font-size: 0.78rem; color: var(--muted); font-family: var(--font-mono); }

        /* ════════════════════════════════════════
           ANIMATIONS
        ════════════════════════════════════════ */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.5s ease both; }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }

        /* ════════════════════════════════════════
           RESPONSIVE
        ════════════════════════════════════════ */
        @media (max-width: 900px) {
            nav, .nav-search { display: none; }
            .nav-menu-btn { display: block; }
        }
        @media (max-width: 768px) {
            .hero h1 { font-size: 3rem; }
            .footer-inner { grid-template-columns: 1fr 1fr; gap: 32px; }
        }
        @media (max-width: 500px) {
            .footer-inner { grid-template-columns: 1fr; }
            .hero-stats { gap: 20px; }
        }

        /* Mobile nav drawer */
        .mobile-nav {
            display: none; flex-direction: column;
            position: fixed; top: 64px; left: 0; right: 0; bottom: 0;
            background: rgba(10,10,15,0.97); backdrop-filter: blur(20px);
            z-index: 99; padding: 32px 2rem; gap: 8px;
        }
        .mobile-nav.open { display: flex; }
        .mobile-nav a {
            color: var(--muted); text-decoration: none; font-size: 1.1rem;
            font-weight: 500; padding: 14px 0; border-bottom: 1px solid var(--border);
            transition: color 0.2s;
        }
        .mobile-nav a:hover { color: var(--neon); }
        .mobile-search {
            display: flex; align-items: center;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 10px; overflow: hidden; margin-bottom: 16px;
        }
        .mobile-search input {
            background: transparent; border: none; outline: none;
            color: var(--text); font-family: var(--font-body); font-size: 1rem;
            padding: 12px 16px; flex: 1;
        }
        .mobile-search input::placeholder { color: var(--muted); }
        .mobile-search button {
            background: transparent; border: none; cursor: pointer;
            color: var(--muted); padding: 12px 16px; font-size: 1rem;
        }
    </style>
</head>
<body>

    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <!-- ════ COOKIE BANNER ════ -->
    <div id="cookieBanner">
        <p>We use cookies to improve your experience and analyze site traffic. By clicking "Accept", you agree to our <a href="cookie.html">Cookie Policy</a>.</p>
        <div class="cookie-btns">
            <button class="btn-cookie-decline" onclick="dismissCookie()">Decline</button>
