                <div class="card-body"><div class="card-meta"><span class="card-genre">Action</span><span class="card-rating"><i class="fas fa-star"></i> 4.7</span></div><h3 class="card-title">Action Blitz</h3><p class="card-desc">Fast-paced action with explosive gameplay — test your reflexes to the limit!</p><div class="card-footer"><span class="card-players"><i class="fas fa-circle"></i> 1.9k playing</span><button class="btn-play"><i class="fas fa-play"></i> Play</button></div></div>
            </div>

            
            
            

            <!-- No results placeholder -->
